# Gemini API Key (get it from https://aistudio.google.com/app/apikey)
# For local development, rename .env.example to .env
# For Netlify/Cloud, add this as an environment variable in the dashboard.
MY_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Botomat WhatsApp API Integration (Israel)
# Create keys here: https://botomat.co.il/developers?tab=keys
BOTOMAT_API_KEY=your_botomat_api_key_here
BOTOMAT_WEBHOOK_SECRET=your_botomat_webhook_secret_here